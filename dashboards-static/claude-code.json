        { "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(claude_code_cost_usage_USD_total[6h])) * 3600 + 2 * stddev(rate(claude_code_cost_usage_USD_total[6h])) * 3600", "legendFormat": "Upper Band", "refId": "B" },
