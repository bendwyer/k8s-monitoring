{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Claude Code usage monitoring — cost, tokens, sessions, tool activity, cache efficiency, and subscription ROI. Inspired by github.com/tcude/grafana-dashboards (claudecode v1 & unified v2).",
