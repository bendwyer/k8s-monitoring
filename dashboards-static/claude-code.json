      "targets": [{ "datasource": { "type": "prometheus", "uid": "${datasource}" }, "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__rate_interval])) / (sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[$__rate_interval])) + sum(rate(claude_code_token_usage_tokens_total{type=\"input\"}[$__rate_interval]))) * 100", "refId": "A" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "light-blue", "value": null }] },
