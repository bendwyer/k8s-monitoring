          { "matcher": { "id": "byName", "options": "Lower Band" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }, { "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
